# ---------- Host port bindings ----------
# Only affect access from your machine; containers always talk to each other by
# service name. Change these if another program already owns the default port
# (a locally installed Redis or MongoDB is the usual culprit).
MONGO_PORT=27017
REDIS_PORT=6379
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ---------- Core ----------
APP_NAME=HealMatrix AI
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173,https://healmatrix.vercel.app

# ---------- MongoDB Atlas ----------
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=healmatrix

# ---------- Security ----------
JWT_SECRET_KEY=change-me-to-a-64-char-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- Redis / Celery (Upstash) ----------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------- Google Gemini ----------
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.2

# ---------- AI agent stack (LangGraph / CrewAI / RAG) ----------
# true (default): backend/worker/beat images install requirements-ai.txt too,
# which pulls in langgraph, crewai, sentence-transformers, faiss-cpu, and
# PyTorch (~1.5 GB extra). Set to false for a faster, smaller build that runs
# the deterministic rule/service fallbacks only (no LangGraph orchestration,
# no CrewAI executive synthesis, no semantic RAG search).
INSTALL_AI=true

# ---------- Cloudinary ----------
CLOUDINARY_CLOUD_NAME=your-cloud
CLOUDINARY_API_KEY=your-key
CLOUDINARY_API_SECRET=your-secret

# ---------- RAG ----------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FAISS_INDEX_PATH=app/rag/index
RAG_TOP_K=5

# ---------- Simulator ----------
SIMULATOR_ENABLED=true
SIMULATOR_TICK_SECONDS=30
SIMULATOR_SEED=42
