flowchart LR
    subgraph Actors
        AD([Admin])
        DR([Doctor])
        NR([Nurse])
        PH([Pharmacist])
        MG([Hospital Manager])
        SO([Sustainability Officer])
        AG([AI Agent Network])
    end

    subgraph HealMatrix["HealMatrix AI Platform"]
        UC1(Manage Users and Roles)
        UC2(Configure Hospital Network)
        UC3(View Audit Trail)
        UC4(Register Patient Arrival)
        UC5(Run AI Triage)
        UC6(Allocate Bed)
        UC7(Predict Discharge)
        UC8(Monitor Inventory)
        UC9(Approve Inter-Hospital Transfer)
        UC10(Track Energy and Water)
        UC11(Schedule Waste Pickup)
        UC12(View Carbon and SDG Score)
        UC13(Dispatch Ambulance)
        UC14(View Digital Twin)
        UC15(Query Knowledge Assistant)
        UC16(Generate PDF Report)
        UC17(Acknowledge Notification)
        UC18(Run Executive Cycle)
        UC19(Inject Simulation Scenario)
    end

    AD --> UC1
    AD --> UC2
    AD --> UC3
    AD --> UC19
    DR --> UC4
    DR --> UC5
    DR --> UC7
    DR --> UC14
    DR --> UC15
    NR --> UC4
