erDiagram
    HOSPITALS ||--o{ DEPARTMENTS : contains
    HOSPITALS ||--o{ USERS : employs
    HOSPITALS ||--o{ STAFF : rosters
    HOSPITALS ||--o{ PATIENTS : registers
    HOSPITALS ||--o{ AMBULANCES : operates
    HOSPITALS ||--o{ INVENTORY : stocks
    HOSPITALS ||--o{ ENERGY_LOGS : meters
    HOSPITALS ||--o{ WATER_LOGS : meters
    HOSPITALS ||--o{ WASTE_RECORDS : generates
    HOSPITALS ||--o{ CARBON_REPORTS : reports
    HOSPITALS ||--o{ NOTIFICATIONS : raises
    HOSPITALS ||--o{ REPORTS : publishes
